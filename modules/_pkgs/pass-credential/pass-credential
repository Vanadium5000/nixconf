#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: pass-credential FIELD [FILE]

Parse a password-store credential entry and print FIELD.

Fields:
  password  Prints the first line for standard pass entries, or the password: field
            for all-key-value entries.
  <name>    Prints the value from the first line whose key before ':' equals <name>.

FILE defaults to stdin. Field keys are matched case-insensitively after trimming whitespace.
EOF
}

trim_key() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

trim_value_prefix() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  printf '%s' "$value"
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 0
fi

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  usage >&2
  exit 2
fi

field="$1"
field_key="${field,,}"
source_file="${2:--}"

if [ -z "$field" ]; then
  printf 'pass-credential: FIELD must not be empty\n' >&2
  exit 2
fi

if [ "$source_file" = "-" ]; then
  content="$(</dev/stdin)"
else
  content="$(<"$source_file")"
fi

first_line="${content%%$'\n'*}"
first_key=""
if [[ "$first_line" == *:* && "$first_line" != otpauth://* ]]; then
  first_key="$(trim_key "${first_line%%:*}")"
fi

if [ "$field" = "password" ] && [ -z "$first_key" ]; then
  printf '%s\n' "$first_line"
  exit 0
fi

while IFS= read -r line || [ -n "$line" ]; do
  [[ "$line" == *:* ]] || continue
  [[ "$line" == otpauth://* ]] && continue

  key="$(trim_key "${line%%:*}")"
  [ "${key,,}" = "$field_key" ] || continue

  value="${line#*:}"
  value="$(trim_value_prefix "$value")"
  printf '%s\n' "$value"
  exit 0
done <<<"$content"

printf 'pass-credential: field not found: %s\n' "$field" >&2
exit 1
