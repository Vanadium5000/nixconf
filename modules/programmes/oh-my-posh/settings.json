{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "terminal_background": "#000000",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "powerline",
          "powerline_symbol": "",
          "leading_powerline_symbol": "",
          "foreground": "#0b1020",
          "background": "#00d0ff",
          "template": " {{ if .WSL }}WSL {{ end }}{{ .Icon }} ",
          "options": {
            "nixos": "",
            "linux": "",
            "macos": "",
            "windows": ""
          }
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#dbeafe",
          "background": "#1e293b",
          "template": "  {{ .Path }} ",
          "options": {
            "style": "agnoster_short",
            "max_depth": 3,
            "folder_icon": "..",
            "home_icon": "~",
            "folder_separator_icon": "/",
            "mapped_locations": {
              "~/nixconf": "nixconf"
            }
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#0f172a",
          "background": "#7dd3fc",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#fbbf24{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#f97316{{ end }}",
            "{{ if gt .Ahead 0 }}#a78bfa{{ end }}",
            "{{ if gt .Behind 0 }}#fb7185{{ end }}"
          ],
          "template": " {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} !{{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} +{{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} *{{ .StashCount }}{{ end }} ",
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": false,
            "branch_identical_icon": "=",
            "branch_ahead_icon": "^",
            "branch_behind_icon": "v",
            "branch_gone_icon": "x",
            "commit_icon": "@",
            "tag_icon": "#",
            "rebase_icon": "rebase:",
            "cherry_pick_icon": "pick:",
            "revert_icon": "revert:",
            "merge_icon": "merge:",
            "no_commits_icon": "new:"
          }
        },
        {
          "type": "executiontime",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#e0f2fe",
          "background": "#334155",
          "template": "  {{ .FormattedMs }} ",
          "options": {
            "threshold": 500,
            "style": "austin"
          }
        },
        {
          "type": "status",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#ecfeff",
          "background": "#16a34a",
          "background_templates": [
            "{{ if .Error }}#dc2626{{ end }}"
          ],
          "template": "{{ if .Error }} ✗ {{ .String }} {{ else }} ✓ {{ end }}",
          "options": {
            "always_enabled": true,
            "status_template": "{{ if eq .Code 0 }}ok{{ else }}{{ .Code }}{{ end }}"
          }
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "overflow": "hide",
      "segments": [
        {
          "type": "session",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "#bae6fd",
          "background": "#0f172a",
          "template": " {{ if .SSHSession }} {{ end }}{{ .UserName }}@{{ .HostName }} "
        },
        {
          "type": "time",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "#dbeafe",
          "background": "#1e293b",
          "template": "  {{ .CurrentDate | date .Format }} ",
          "options": {
            "time_format": "15:04:05"
          }
        }
      ]
    }
  ]
}
